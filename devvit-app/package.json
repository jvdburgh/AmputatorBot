{
  "name": "amputatorbot-app",
  "version": "5.0.0",
  "private": true,
  "description": "Detects AMP URLs in comments and posts, replies with the canonical non-AMP link.",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "playtest": "devvit playtest",
    "upload": "vite build && devvit upload",
    "check": "tsgo --noEmit",
    "lint": "biome check",
    "format": "biome format --write",
    "test": "vitest run"
  },
  "dependencies": {
    "@devvit/web": "^0.13.2",
    "@hono/node-server": "^2.0.4",
    "hono": "^4.12.23"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@devvit/start": "^0.13.2",
    "@types/node": "^25.9.2",
    "@typescript/native-preview": "latest",
    "devvit": "0.13.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "license": "GPL-3.0-or-later"
}
