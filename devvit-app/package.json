{
  "name": "amputatorbot-app",
  "version": "5.0.0",
  "private": true,
  "description": "Detects AMP URLs in comments and posts, replies with the canonical non-AMP link.",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "playtest": "devvit playtest",
    "upload": "vite build && devvit upload",
    "check": "tsgo --noEmit",
    "lint": "biome check",
    "format": "biome format --write",
    "test": "vitest run"
  },
  "dependencies": {
    "@devvit/web": "^0.13.6",
    "@hono/node-server": "^2.0.6",
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@devvit/start": "^0.13.6",
    "@types/node": "^26.1.0",
    "@typescript/native-preview": "latest",
    "devvit": "0.13.6",
    "typescript": "^6.0.3",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  },
  "license": "GPL-3.0-or-later"
}
