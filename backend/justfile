# amputatorbot-backend tasks

# Default: list recipes
default:
    @just --list

# Run all checks (CI equivalent)
check: fmt-check lint test deny

# Apply formatting
fmt:
    cargo fmt --all

# Verify formatting
fmt-check:
    cargo fmt --all -- --check

# Lint, deny warnings
lint:
    cargo clippy --all-targets --all-features -- -D warnings

# Run tests (nextest if available, falls back to cargo test).
# `--no-tests=pass` keeps the run green during M1 scaffolding when no tests exist yet;
# real tests arrive in M2.
test:
    cargo nextest run --all-features --no-tests=pass || cargo test --all-features

# Security + license audit
deny:
    cargo deny check

# Watch + auto-rebuild for local dev
dev:
    cargo watch -x run

# Run the parity test against recorded HTML fixtures, streaming output
# in real time (default nextest hides stdout/stderr for passing tests).
# Also writes a Markdown summary to tests/parity-report.md.
parity:
    cargo nextest run --test parity --no-capture

# Record HTML fixtures from a URLConversions CSV. Idempotent — re-runnable.
record-fixtures CSV="tests/fixtures/urlconversions/URLConversions_500_including_failed_and_false_positives.csv":
    cargo run --release --bin record_fixtures -- --input {{CSV}}

# Build release binary
build:
    cargo build --release

# Build the container image locally
docker-build:
    docker build -t amputatorbot-backend:dev .
