---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description?: string;
  updated?: string;
}

const { title, description, updated } = Astro.props;
---

<Layout title={`${title} — AmputatorBot`} description={description}>
  <article class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16">
    <header class="mb-8 border-b border-border pb-6">
      <h1 class="text-4xl font-semibold tracking-tight">{title}</h1>
      {
        description ? (
          <p class="mt-2 text-lg text-muted-foreground">{description}</p>
        ) : null
      }
      {
        updated ? (
          <p class="mt-2 text-xs text-muted-foreground">Last updated {updated}</p>
        ) : null
      }
    </header>
    <div
      class="prose-fallback space-y-5 text-foreground [&_a]:font-medium [&_a]:text-brand [&_a]:underline-offset-4 hover:[&_a]:underline [&_blockquote]:border-l-2 [&_blockquote]:border-border [&_blockquote]:pl-4 [&_blockquote]:text-muted-foreground [&_code]:rounded-sm [&_code]:bg-muted [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:text-sm [&_h2]:mt-10 [&_h2]:text-2xl [&_h2]:font-semibold [&_h2]:tracking-tight [&_h3]:mt-6 [&_h3]:text-xl [&_h3]:font-semibold [&_li]:my-1 [&_ol]:list-decimal [&_ol]:space-y-1 [&_ol]:pl-6 [&_p]:leading-relaxed [&_ul]:list-disc [&_ul]:space-y-1 [&_ul]:pl-6"
    >
      <slot />
    </div>
  </article>
</Layout>
