---
import { clsx } from 'clsx';

export interface Props {
  variant: 'desktop' | 'mobile';
}

interface NavLink {
  href: string;
  label: string;
  external?: boolean;
}

const { variant } = Astro.props;

const links: NavLink[] = [
  { href: '/', label: 'Converter' },
  {
    href: 'https://www.reddit.com/r/AmputatorBot/comments/ehrq3z/why_did_i_build_amputatorbot/',
    label: 'Why',
    external: true,
  },
  {
    href: 'https://www.reddit.com/user/AmputatorBot',
    label: 'u/AmputatorBot',
    external: true,
  },
  {
    href: 'https://github.com/jvdburgh/AmputatorBot',
    label: 'GitHub',
    external: true,
  },
  { href: '/api/docs', label: 'API' },
];

const itemClass = clsx(
  'transition-colors hover:bg-accent',
  variant === 'desktop' &&
    'rounded-md px-2 py-1.5 text-muted-foreground hover:text-foreground sm:px-3',
  variant === 'mobile' && 'block px-5 py-3 text-base text-foreground',
);

const listClass = clsx({
  'flex items-center gap-1 text-sm sm:gap-2': variant === 'desktop',
  'divide-y divide-border': variant === 'mobile',
});
---

<ul class={listClass}>
  {
    links.map(({ href, label, external }) => (
      <li>
        <a
          href={href}
          class={itemClass}
          {...(external
            ? { rel: 'noopener noreferrer', target: '_blank' }
            : {})}
        >
          {label}
        </a>
      </li>
    ))
  }
</ul>
