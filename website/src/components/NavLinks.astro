---
export interface Props {
  variant: 'desktop' | 'mobile';
}

const { variant } = Astro.props;

const links = [
  { href: '/', label: 'Converter' },
  {
    href: 'https://www.reddit.com/r/AmputatorBot/comments/ehrq3z/why_did_i_build_amputatorbot/',
    label: 'Why',
    external: true,
  },
  {
    href: 'https://www.reddit.com/user/AmputatorBot',
    label: 'u/AmputatorBot',
    external: true,
  },
  {
    href: 'https://github.com/KilledMufasa/AmputatorBot',
    label: 'GitHub',
    external: true,
  },
  { href: '/api/docs', label: 'API' },
];

const itemClass =
  variant === 'desktop'
    ? 'rounded-md px-2 py-1.5 text-muted-foreground transition-colors hover:bg-accent hover:text-foreground sm:px-3'
    : 'block px-5 py-3 text-base text-foreground transition-colors hover:bg-accent';
---

<ul
  class={
    variant === 'desktop'
      ? 'flex items-center gap-1 text-sm sm:gap-2'
      : 'divide-y divide-border'
  }
>
  {
    links.map(({ href, label, external }) => (
      <li>
        <a
          href={href}
          class={itemClass}
          {...(external
            ? { rel: 'noopener noreferrer', target: '_blank' }
            : {})}
        >
          {label}
        </a>
      </li>
    ))
  }
</ul>