---
// Bottom-of-page links. Mirrors the legacy site's nav bar but split into
// logical groups. Sponsorship and the subreddit live here because they're
// less load-bearing than About/FAQ in the top nav.
const footerColumns: Array<{
  heading: string;
  links: Array<{ href: string; label: string; external?: boolean }>;
}> = [
  {
    heading: 'AmputatorBot',
    links: [
      { href: '/about', label: 'About AMP & why' },
      { href: '/faq', label: 'FAQ' },
      {
        href: 'https://www.reddit.com/r/AmputatorBot/',
        label: 'r/AmputatorBot',
        external: true,
      },
      {
        href: 'https://www.reddit.com/r/AmputatorBot/comments/ch9fxp/changelog_of_amputatorbot/',
        label: 'Changelog',
        external: true,
      },
    ],
  },
  {
    heading: 'Use',
    links: [
      { href: '/', label: 'Web converter' },
      {
        href: 'https://www.reddit.com/user/AmputatorBot',
        label: 'Summon u/AmputatorBot',
        external: true,
      },
      {
        href: 'https://documenter.getpostman.com/view/12422626/UVC3n93T',
        label: 'API documentation',
        external: true,
      },
    ],
  },
  {
    heading: 'Source',
    links: [
      {
        href: 'https://github.com/KilledMufasa/AmputatorBot',
        label: 'GitHub repo',
        external: true,
      },
      {
        href: 'https://github.com/KilledMufasa/AmputatorBot/issues',
        label: 'Report an issue',
        external: true,
      },
      {
        href: 'https://www.reddit.com/message/compose/?to=Killed_Mufasa',
        label: 'Contact u/Killed_Mufasa',
        external: true,
      },
    ],
  },
  {
    heading: 'Support',
    links: [
      {
        href: 'https://www.paypal.com/cgi-bin/webscr?cmd=_s-xclick&hosted_button_id=EU6ZFKTVT9VH2',
        label: 'Sponsor (PayPal)',
        external: true,
      },
      {
        href: 'https://u24.gov.ua/',
        label: 'Donate to Ukraine (U24)',
        external: true,
      },
    ],
  },
];
---

<footer class="border-t border-border bg-muted/30 mt-16">
  <div
    class="mx-auto max-w-5xl gap-8 px-4 py-10 grid grid-cols-2 sm:grid-cols-4 sm:px-6"
  >
    {
      footerColumns.map(({ heading, links }) => (
        <div>
          <h3 class="mb-3 text-sm font-semibold text-foreground">{heading}</h3>
          <ul class="space-y-2 text-sm">
            {links.map(({ href, label, external }) => (
              <li>
                <a
                  href={href}
                  class="text-muted-foreground transition-colors hover:text-foreground"
                  {...(external
                    ? { rel: 'noopener noreferrer', target: '_blank' }
                    : {})}
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
  <div
    class="mx-auto max-w-5xl border-t border-border px-4 py-6 text-xs text-muted-foreground sm:px-6"
  >
    <p>
      Built and maintained by
      <a
        href="https://www.reddit.com/user/Killed_Mufasa"
        rel="noopener noreferrer"
        target="_blank"
        class="underline-offset-4 hover:underline"
      >
        u/Killed_Mufasa
      </a>. AmputatorBot is open source and free to use.
    </p>
  </div>
</footer>
