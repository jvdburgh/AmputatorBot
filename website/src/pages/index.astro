---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="text-4xl font-semibold tracking-tight">AmputatorBot</h1>
    <p class="mt-3 text-lg text-zinc-700">
      Strips AMP from URLs and returns the canonical link.
    </p>
    <p class="mt-8 text-sm text-zinc-500">
      M1 placeholder — the converter form, FAQ, and About arrive in M5.
    </p>
  </main>
</Layout>
